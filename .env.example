# ── Discord bot ────────────────────────────────────────────────────────────
# Required. Bot token from Discord Developer Portal.
TOKEN_BOT_RECEPTOR=your-discord-bot-token

# Required. The default channel where /alerts/* broadcasts go.
ID_CANAL_DESTINO=000000000000000000

# ── Graal Online Era event roles (mentioned in alerts) ─────────────────────
# Role mentioned when /alerts/doublecoins fires
ID_DEL_ROL=
# Role mentioned when /alerts/pvp-normal fires
ID_PVP_NORMAL_ROL=
# Role mentioned when /alerts/plasma-event fires
ID_PVP_EVENT_ROL=

# ── Discord channel monitoring (auto-import events) ────────────────────────
# Defaults to ID_CANAL_DESTINO if unset.
MONITORED_CHANNEL_ID=
# If set, only imports from this specific bot's messages.
OLD_BOT_USER_ID=
# Whether to import bot messages from the monitored channel. Default: true.
IMPORT_BOT_MESSAGES=true

# ── HTTP API ───────────────────────────────────────────────────────────────
# Port for the Express server. Defaults to 3100.
PORT=3100
# Bearer token required for all /alerts/* and /messages/send endpoints.
# Leave empty to disable auth (NOT recommended in production).
ALERT_API_TOKEN=

# ── Optional integrations ──────────────────────────────────────────────────
# Google Safe Browsing API key — enables an extra detection layer in LinkGuard.
SAFE_BROWSING_API_KEY=

# ── Moderation ─────────────────────────────────────────────────────────────
# Optional: fixed ID for the "Muted" role. If empty, bot finds it by name
# or creates it automatically per server.
MUTED_ROLE_ID=

# Discord user ID of the bot owner. Required for $ricky logs and $ricky helpricky.
OWNER_ID=
